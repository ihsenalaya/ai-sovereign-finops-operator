{
  "annotations": {
    "list": []
  },
  "editable": true,
  "schemaVersion": 39,
  "title": "AI FinOps & Sovereign Operator",
  "tags": [
    "ai-finops",
    "sovereignty",
    "cncf"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "1m",
  "panels": [
    {
      "type": "stat",
      "title": "Total cost (EUR) \u2014 observed",
      "description": "Real spend so far: measured gateway tokens x real per-model list prices.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 4
        }
      },
      "targets": [
        {
          "expr": "sum(ai_finops_cost_eur)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tokens (total in + out)",
      "description": "Real total tokens measured by the gateway across all apps.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(ai_finops_input_tokens) + sum(ai_finops_output_tokens)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Requests (total)",
      "description": "Total LLM requests routed through the gateway and accounted by the operator.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(ai_finops_requests)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Budget usage (%) by policy",
      "description": "Forecast monthly spend vs the monthly budget cap, per AIBudgetPolicy (one bar per budget).",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 150,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ai_finops_budget_usage_percent",
          "legendFormat": "{{namespace}}/{{policy}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cost (EUR) by namespace",
      "description": "Real per-namespace spend over time.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "ai_finops_cost_eur",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens by namespace (input / output)",
      "description": "Real token volume measured by the gateway, per namespace.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "ai_finops_input_tokens",
          "legendFormat": "in {{namespace}}",
          "refId": "A"
        },
        {
          "expr": "ai_finops_output_tokens",
          "legendFormat": "out {{namespace}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Requests violating sovereignty (by app)",
      "description": "Current number of requests each app routed to a non-compliant (forbidden-zone) provider. Critical zone violations shown (warning count is identical).",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (namespace, application) (ai_finops_sovereignty_requests{severity=\"critical\"})",
          "legendFormat": "{{namespace}}/{{application}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Spend by sovereignty zone (EUR)",
      "description": "How much real spend goes to each sovereignty zone (provider data residency). EU = compliant (allowed); US = forbidden by the policy. The share leaving the EU is the sovereign-spend exposure. Source: ai_finops_cost_by_zone_eur.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "expr": "ai_finops_cost_by_zone_eur",
          "legendFormat": "{{zone}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 4,
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "US"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "EU"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Enforcement actions (sovereignty)",
      "description": "Ce que l'op\u00e9rateur D\u00c9CIDE et APPLIQUE pour chaque workload non conforme, selon le mode de la policy. action: report (reportOnly) / warn (alerte) / reroute (mod\u00e8le interdit -> backend conforme, R\u00c9\u00c9CRIT au niveau de l'Envoy AI Gateway) / block. actuated=true = appliqu\u00e9 de bout en bout : warn/report toujours, et reroute d\u00e9sormais ACTU\u00c9 dans le plan de donn\u00e9es (slice 2). Source: ai_finops_enforcement_actions.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "expr": "ai_finops_enforcement_actions",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "Value": true
            },
            "renameByName": {
              "policy": "Policy",
              "namespace": "Namespace",
              "application": "Application",
              "mode": "Mode",
              "action": "Action",
              "actuated": "Actuated"
            },
            "indexByName": {
              "namespace": 0,
              "application": 1,
              "mode": 2,
              "action": 3,
              "actuated": 4,
              "policy": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Action"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "block": {
                        "color": "red",
                        "index": 0
                      },
                      "reroute": {
                        "color": "orange",
                        "index": 1
                      },
                      "warn": {
                        "color": "yellow",
                        "index": 2
                      },
                      "report": {
                        "color": "blue",
                        "index": 3
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "title": "Routing Score & Souverainet\u00e9",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 46
      }
    },
    {
      "type": "table",
      "title": "Score de routage par application / mod\u00e8le",
      "description": "Score composite [0\u20131] : 40% co\u00fbt + 30% qualit\u00e9 + 20% latence + 10% fiabilit\u00e9. Score = 0 si le mod\u00e8le viole la politique de souverainet\u00e9 active.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 47
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "datasource": null,
          "expr": "ai_finops_routing_score",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "namespace": "Namespace",
              "application": "Application",
              "model": "Mod\u00e8le",
              "latency_telemetry": "Latence dispo",
              "Value": "Score final [0-1]"
            },
            "indexByName": {
              "namespace": 0,
              "application": 1,
              "model": 2,
              "latency_telemetry": 3,
              "Value": 4
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": "",
            "sort": [
              {
                "field": "Score final [0-1]",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.75
              }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Score final [0-1]"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          }
        ]
      }
    },
    {
      "type": "timeseries",
      "title": "\u00c9volution du score de routage dans le temps",
      "description": "Suivi temporel du score composite par application/mod\u00e8le. Un score tombant \u00e0 0 indique une violation de souverainet\u00e9 d\u00e9tect\u00e9e.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 47
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "datasource": null,
          "expr": "ai_finops_routing_score",
          "legendFormat": "{{namespace}}/{{application}} \u2014 {{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.75
              }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 68
      },
      "title": "Radar \u2014 Comparaison multi-dimensionnelle des mod\u00e8les",
      "type": "row"
    },
    {
      "type": "ae3e-plotly-panel",
      "id": 50,
      "title": "Radar \u2014 Score par dimension pour chaque mod\u00e8le",
      "description": "Chaque polygone = un mod\u00e8le. Les 5 axes = Co\u00fbt \u00b7 Qualit\u00e9 \u00b7 Latence \u00b7 Fiabilit\u00e9 \u00b7 Souverainet\u00e9 (0 = mauvais, 1 = parfait). Un grand polygone = un bon mod\u00e8le.",
      "gridPos": {
        "h": 16,
        "w": 14,
        "x": 0,
        "y": 69
      },
      "options": {
        "script": "\nvar dims = {cost: 0, quality: 1, latency: 2, reliability: 3, sovereignty: 4};\nvar theta = ['Co\u00fbt', 'Qualit\u00e9', 'Latence', 'Fiabilit\u00e9', 'Souverainet\u00e9', 'Co\u00fbt'];\nvar models = {};\n\n(data.series || []).forEach(function(frame) {\n  var refId = (frame.refId || '').toLowerCase();\n  if (!dims.hasOwnProperty(refId)) return;\n  (frame.fields || []).forEach(function(field) {\n    if (field.type !== 'number') return;\n    var labels = field.labels || {};\n    var model = labels.model || labels.Model || 'unknown';\n    if (!models[model]) models[model] = {cost:0, quality:0, latency:0, reliability:0, sovereignty:0};\n    var vals = field.values;\n    var v = (vals && vals.length > 0) ? vals[vals.length - 1] : (vals && vals.get ? vals.get(0) : 0);\n    models[model][refId] = v || 0;\n  });\n});\n\nvar traces = Object.keys(models).map(function(model, idx) {\n  var s = models[model];\n  var r = [s.cost, s.quality, s.latency, s.reliability, s.sovereignty, s.cost];\n  return {\n    type: 'scatterpolar',\n    r: r,\n    theta: theta,\n    fill: 'toself',\n    name: model,\n    opacity: 0.75\n  };\n});\n\nreturn {\n  data: traces,\n  layout: {\n    paper_bgcolor: 'transparent',\n    plot_bgcolor: 'transparent',\n    font: {color: '#d0d0d0', size: 13},\n    polar: {\n      bgcolor: 'rgba(30,30,40,0.5)',\n      radialaxis: {\n        visible: true,\n        range: [0, 1],\n        tickfont: {size: 10},\n        gridcolor: 'rgba(200,200,200,0.2)',\n        linecolor: 'rgba(200,200,200,0.3)'\n      },\n      angularaxis: {\n        gridcolor: 'rgba(200,200,200,0.2)',\n        linecolor: 'rgba(200,200,200,0.3)'\n      }\n    },\n    showlegend: true,\n    legend: {orientation: 'h', y: -0.15},\n    margin: {t: 30, b: 60, l: 40, r: 40}\n  },\n  config: {responsive: true}\n};\n",
        "onclick": "",
        "onrender": ""
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg by(model)(ai_finops_cost_score)",
          "instant": true,
          "legendFormat": "{{model}}",
          "refId": "cost"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg by(model)(ai_finops_quality_score)",
          "instant": true,
          "legendFormat": "{{model}}",
          "refId": "quality"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg by(model)(ai_finops_latency_score)",
          "instant": true,
          "legendFormat": "{{model}}",
          "refId": "latency"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg by(model)(ai_finops_reliability_score)",
          "instant": true,
          "legendFormat": "{{model}}",
          "refId": "reliability"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "avg by(model)(ai_finops_sovereignty_score)",
          "instant": true,
          "legendFormat": "{{model}}",
          "refId": "sovereignty"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Shadow-AI \u2014 applications contournant le gateway",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "expr": "sum by (namespace, application) (ai_finops_shadow_ai_egress)",
          "legendFormat": "{{namespace}}/{{application}}",
          "refId": "A"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {},
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "unit": "short",
          "displayName": ""
        },
        "overrides": []
      }
    }
  ]
}