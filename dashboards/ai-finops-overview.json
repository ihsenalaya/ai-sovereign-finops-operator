{
  "annotations": {
    "list": []
  },
  "editable": true,
  "schemaVersion": 39,
  "title": "AI Sovereign FinOps — Overview",
  "tags": [
    "ai-finops",
    "sovereignty",
    "cncf"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Total cost (EUR) — observed",
      "description": "Real spend so far: measured gateway tokens x real per-model list prices.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 4
        }
      },
      "targets": [
        {
          "expr": "sum(ai_finops_cost_eur)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Tokens (total in + out)",
      "description": "Real total tokens measured by the gateway across all apps.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "targets": [
        {
          "expr": "sum(ai_finops_input_tokens) + sum(ai_finops_output_tokens)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Requests (total)",
      "description": "Total LLM requests routed through the gateway and accounted by the operator.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(ai_finops_requests)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Budget usage (%) by policy",
      "description": "Forecast monthly spend vs the monthly budget cap, per AIBudgetPolicy (one bar per budget).",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 150,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "ai_finops_budget_usage_percent",
          "legendFormat": "{{namespace}}/{{policy}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cost (EUR) by namespace",
      "description": "Real per-namespace spend over time.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 4,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "ai_finops_cost_eur",
          "legendFormat": "{{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tokens by namespace (input / output)",
      "description": "Real token volume measured by the gateway, per namespace.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "expr": "ai_finops_input_tokens",
          "legendFormat": "in {{namespace}}",
          "refId": "A"
        },
        {
          "expr": "ai_finops_output_tokens",
          "legendFormat": "out {{namespace}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Requests violating sovereignty (by app)",
      "description": "Current number of requests each app routed to a non-compliant (forbidden-zone) provider. Critical zone violations shown (warning count is identical).",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum by (namespace, application) (ai_finops_sovereignty_requests{severity=\"critical\"})",
          "legendFormat": "{{namespace}}/{{application}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Spend by sovereignty zone (EUR)",
      "description": "How much real spend goes to each sovereignty zone (provider data residency). EU = compliant (allowed); US = forbidden by the policy. The share leaving the EU is the sovereign-spend exposure. Source: ai_finops_cost_by_zone_eur.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "expr": "ai_finops_cost_by_zone_eur",
          "legendFormat": "{{zone}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyEUR",
          "decimals": 4,
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "US"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "EU"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Enforcement actions (sovereignty)",
      "description": "Ce que l'opérateur DÉCIDE et APPLIQUE pour chaque workload non conforme, selon le mode de la policy. action: report (reportOnly) / warn (alerte) / reroute (modèle interdit -> backend conforme, RÉÉCRIT au niveau de l'Envoy AI Gateway) / block. actuated=true = appliqué de bout en bout : warn/report toujours, et reroute désormais ACTUÉ dans le plan de données (slice 2). Source: ai_finops_enforcement_actions.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "expr": "ai_finops_enforcement_actions",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "Value": true
            },
            "renameByName": {
              "policy": "Policy",
              "namespace": "Namespace",
              "application": "Application",
              "mode": "Mode",
              "action": "Action",
              "actuated": "Actuated"
            },
            "indexByName": {
              "namespace": 0,
              "application": 1,
              "mode": 2,
              "action": 3,
              "actuated": 4,
              "policy": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Action"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "block": {
                        "color": "red",
                        "index": 0
                      },
                      "reroute": {
                        "color": "orange",
                        "index": 1
                      },
                      "warn": {
                        "color": "yellow",
                        "index": 2
                      },
                      "report": {
                        "color": "blue",
                        "index": 3
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "title": "Shadow-AI egress details",
      "description": "Direct LLM egress detected outside the gateway. This is the operational panel: who bypassed the gateway, which provider/zone was hit, and how many connections were observed.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "datasource": null,
          "expr": "ai_finops_shadow_ai_egress",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "namespace": "Namespace",
              "application": "Application",
              "provider": "Provider",
              "zone": "Zone",
              "severity": "Severity",
              "Value": "Connections"
            },
            "indexByName": {
              "namespace": 0,
              "application": 1,
              "provider": 2,
              "zone": 3,
              "severity": 4,
              "Value": 5
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Severity"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "critical": {
                        "color": "red",
                        "index": 0
                      },
                      "warning": {
                        "color": "orange",
                        "index": 1
                      },
                      "info": {
                        "color": "blue",
                        "index": 2
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Connections"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      }
    },
    {
      "type": "bargauge",
      "title": "Shadow-AI hotspots by workload",
      "description": "Most actionable Shadow-AI view: which workload bypasses the gateway, in which zone, and with how many direct connections.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": false,
        "text": {},
        "valueMode": "color"
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "datasource": null,
          "expr": "sum by (namespace, application, zone) (ai_finops_shadow_ai_egress)",
          "legendFormat": "{{namespace}} / {{application}} → {{zone}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "min": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Observed latency telemetry",
      "description": "Observed latency is shown only when the operator scraped real gateway duration telemetry. The telemetry-available series makes missing measurements explicit. Quality/routing scores are intentionally left to the future score/star panels.",
      "datasource": "${datasource}",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "pluginVersion": "11.2.2",
      "targets": [
        {
          "datasource": null,
          "expr": "ai_finops_measured_latency_millis or ai_finops_latency_telemetry_available",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "__name__": "Metric",
              "namespace": "Namespace",
              "application": "Application",
              "model": "Model",
              "telemetry_available": "Telemetry available",
              "source": "Source",
              "Value": "Value"
            },
            "indexByName": {
              "__name__": 0,
              "namespace": 1,
              "application": 2,
              "model": 3,
              "telemetry_available": 4,
              "source": 5,
              "Value": 6
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": "",
            "sort": [
              {
                "field": "Namespace",
                "desc": false
              },
              {
                "field": "Application",
                "desc": false
              },
              {
                "field": "Metric",
                "desc": false
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 3
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "gradient"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Telemetry available"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "color": "green",
                        "index": 0
                      },
                      "false": {
                        "color": "red",
                        "index": 1
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
